# Server Configuration
PORT=5000
NODE_ENV=development

# Database Provider
# Desarrollo y produccion: postgres sobre Supabase
# sqlite queda solo como origen de migracion legacy
# postgres | supabase
DB_PROVIDER=postgres
DATABASE_URL=
SUPABASE_DB_URL=
SUPABASE_PROJECT_ID=tu-project-id
SUPABASE_DB_PASSWORD=tu-db-password
DB_SSL=true
SOURCE_SQLITE_PATH=./database.sqlite

# Business Defaults
BUSINESS_NAME=Mi Local
BUSINESS_TIMEZONE=America/Buenos_Aires
BUSINESS_CURRENCY=ARS

# Upload Provider
# Supabase Storage es el provider recomendado y soportado para despliegue compartido
UPLOAD_PROVIDER=supabase
MAX_FILE_SIZE=5242880

# Supabase Storage
SUPABASE_URL=https://tu-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_STORAGE_BUCKET=uploads

# Socket.io Configuration
SOCKET_CORS_ORIGIN=http://localhost:3000

# Frontend URL usada por exportadores/headless browser
CLIENT_URL=http://localhost:3000
