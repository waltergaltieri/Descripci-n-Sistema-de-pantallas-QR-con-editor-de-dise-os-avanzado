# Server Configuration
PORT=5000
NODE_ENV=development

# Database Provider
# Desarrollo local: sqlite
# Produccion/staging compartido: postgres
# sqlite | postgres | supabase
DB_PROVIDER=sqlite
SQLITE_PATH=./database.sqlite
DATABASE_URL=
SUPABASE_DB_URL=
DB_SSL=true

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_here

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Business Defaults
BUSINESS_NAME=Mi Local
BUSINESS_TIMEZONE=America/Buenos_Aires
BUSINESS_CURRENCY=ARS

# Upload Provider
# Desarrollo local: local
# Produccion/staging compartido: supabase u otro storage compartido
# local | supabase
UPLOAD_PROVIDER=local
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# Supabase Storage
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=

# Socket.io Configuration
SOCKET_CORS_ORIGIN=http://localhost:3000
